# Anthropic API Key (Claude)
KIRINUKI_ANTHROPIC_API_KEY=

# OpenAI API Key (Embedding)
KIRINUKI_OPENAI_API_KEY=

# Database path (default: ~/.kirinuki/data.db)
# KIRINUKI_DB_PATH=

# LLM model (default: claude-haiku-4-5-20251001)
# KIRINUKI_LLM_MODEL=

# Embedding model (default: text-embedding-3-small)
# KIRINUKI_EMBEDDING_MODEL=

# Embedding dimensions (default: 1536)
# KIRINUKI_EMBEDDING_DIMENSIONS=
